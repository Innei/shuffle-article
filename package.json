{
  "name": "shuffle-article-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "dev": "pnpm --filter @article-shuffle/demo dev",
    "preview": "pnpm --filter @article-shuffle/demo preview",
    "check": "pnpm -r --if-present check",
    "test": "pnpm -r --if-present test",
    "build:packages": "pnpm -r --filter \"./packages/*\" build",
    "build:demo": "pnpm --filter @article-shuffle/demo build",
    "build": "pnpm run check && pnpm run test && pnpm run build:packages && pnpm run build:demo",
    "deploy": "pnpm run build && gh-pages -d apps/demo/dist"
  }
}
