  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "article-shuffle": "workspace:*"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
