{
  "name": "react-article-shuffle",
  "version": "0.1.1",
  "description": "React components for article-shuffle.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Innei/shuffle-article.git",
    "directory": "packages/react"
  },
  "homepage": "https://shuffle-article.vercel.app",
  "bugs": {
    "url": "https://github.com/Innei/shuffle-article/issues"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "article-shuffle": "workspace:*"
  },
  "devDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
  "keywords": [
    "react",
    "react-component",
    "text-scramble",
    "anti-copy",
    "copy-protection",
    "content-protection",
    "article-shuffle"
  ],
  "author": "Innei",
  "license": "MIT"
}
