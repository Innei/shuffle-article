{
  "name": "article-shuffle",
  "version": "2.1.1",
  "description": "Shuffle text in the DOM while preserving visual rendering for lightweight copy protection.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Innei/shuffle-article.git",
    "directory": "packages/core"
  },
  "homepage": "https://shuffle-article.vercel.app",
  "bugs": {
    "url": "https://github.com/Innei/shuffle-article/issues"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3"
  },
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm run build"
  },
  "keywords": [
    "shuffle",
    "anti-copy",
    "browser",
    "copy-protection",
    "dom-manipulation",
    "text-scramble",
    "dom",
    "content-protection",
    "pretext"
  ],
  "author": "Innei",
  "license": "MIT"
}
